# Copier en terraform.tfvars et adapter. NE PAS COMMITER (cf .gitignore).
project     = "audioprothese"
environment = "mvp"
location    = "francecentral"

# FinOps — dimensionnement minimal
aks_node_count = 1
aks_node_size  = "Standard_B2s"
postgres_sku   = "B_Standard_B1ms"

# Budget et alertes (mettez votre e-mail pour activer le garde-fou)
monthly_budget_amount = 50
budget_alert_emails   = ["mougammadouzaafir@gmail.com"]
