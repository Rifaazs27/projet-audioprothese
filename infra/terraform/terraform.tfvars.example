# Copier en terraform.tfvars et adapter si besoin. NE PAS COMMITER (.gitignore).
# La CI fonctionne avec les valeurs par défaut ; ce fichier est surtout utile
# pour un apply manuel en local.
project     = "audioprothese"
environment = "mvp"
location    = "polandcentral"

# FinOps — dimensionnement minimal
aks_node_count = 1
aks_node_size  = "Standard_B2s_v2"
postgres_sku   = "B_Standard_B1ms"

# On-premise simulé (VM + MinIO). Mettre false pour économiser ~20 $/mois.
enable_onprem  = true
onprem_vm_size = "Standard_B1ms"

# Budget et alertes (mettez votre e-mail pour activer le garde-fou)
monthly_budget_amount = 50
budget_alert_emails   = ["mougammadouzaafir@gmail.com"]
